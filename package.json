{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"resources/js/**/*.{js,jsx,json}\" \"resources/css/**/*.css\" \"scripts/**/*.mjs\" \"package.json\"",
        "i18n:extract": "node scripts/i18n-extract.mjs",
        "i18n:extract:write": "node scripts/i18n-extract.mjs --write",
        "preview": "vite preview"
    },
    "dependencies": {
        "i18next": "^26.1.0",
        "i18next-browser-languagedetector": "^8.2.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-i18next": "^17.0.7",
        "react-router-dom": "^7.15.0",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@babel/generator": "^7.29.1",
        "@babel/parser": "^7.29.3",
        "@babel/traverse": "^7.29.0",
        "@babel/types": "^7.29.0",
        "@vitejs/plugin-react": "^6.0.1",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.3",
        "vite": "^8.0.0"
    }
}
